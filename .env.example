# value.js — environment template (K.W2 CI/CD lane).
# Copy to `.env` for local dev/deploy. scripts/dev.sh + scripts/deploy.sh source
# `$ROOT/.env`. NEVER commit a real `.env` (secrets). Two-tier discipline: dev
# vars default to a sentinel; deploy/CI vars are required by their consumer.

# ── Demo (frontend) ──────────────────────────────────────────────────────────
# Palette API base. Unset in production builds → defaults to the live spine
# (https://api.color.babb.dev). Under e2e it is overridden to the same-origin
# dev server (playwright.config.ts) so no cross-origin fetch fires (inv-K-5).
VITE_API_URL=

# ── api/ (backend) ───────────────────────────────────────────────────────────
# Mongo connection — replica set rs0 is REQUIRED (H1 services.withTransaction is
# rejected by a standalone mongod). Dev: a single-node replica set.
MONGODB_URI=mongodb://localhost:27017/palette?replicaSet=rs0
ADMIN_TOKEN=

# ── Deploy (babb.dev spine — DEC-9 git-push→webhook, NO rsync) ────────────────
# api → api.color.babb.dev (Docker :8130). Demo → color.babb.dev (Cloudflare Pages).
WEBHOOK_URL=https://deploy.babb.dev/hooks/value-js
API_HEALTH_URL=https://api.color.babb.dev/
GATE_RETRIES=30
GATE_INTERVAL=2
# Cloudflare Pages (frontend) — host/CI only, never committed.
PAGES_PROJECT=value-js
PAGES_BRANCH=master
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
