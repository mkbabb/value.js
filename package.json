{
    "name": "@mkbabb/value.js",
    "version": "3.1.0",
    "description": "CSS value units for color, length, angles, & c.",
    "license": "MIT",
    "keywords": [
        "css",
        "value",
        "unit",
        "value-unit",
        "css-value-unit",
        "color",
        "color-space",
        "rgb",
        "xyz",
        "lab"
    ],
    "type": "module",
    "main": "./dist/value.js",
    "types": "./dist/index.d.ts",
    "sideEffects": [
        "./demo/**",
        "**/*.css"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/value.js",
            "default": "./dist/value.js"
        },
        "./color": {
            "types": "./dist/subpaths/color.d.ts",
            "import": "./dist/subpaths/color.js",
            "default": "./dist/subpaths/color.js"
        },
        "./parsing": {
            "types": "./dist/subpaths/parsing.d.ts",
            "import": "./dist/subpaths/parsing.js",
            "default": "./dist/subpaths/parsing.js"
        },
        "./math": {
            "types": "./dist/subpaths/math.d.ts",
            "import": "./dist/subpaths/math.js",
            "default": "./dist/subpaths/math.js"
        },
        "./easing": {
            "types": "./dist/subpaths/easing.d.ts",
            "import": "./dist/subpaths/easing.js",
            "default": "./dist/subpaths/easing.js"
        },
        "./transform": {
            "types": "./dist/subpaths/transform.d.ts",
            "import": "./dist/subpaths/transform.js",
            "default": "./dist/subpaths/transform.js"
        },
        "./units": {
            "types": "./dist/subpaths/units.d.ts",
            "import": "./dist/subpaths/units.js",
            "default": "./dist/subpaths/units.js"
        },
        "./quantize": {
            "types": "./dist/subpaths/quantize.d.ts",
            "import": "./dist/subpaths/quantize.js",
            "default": "./dist/subpaths/quantize.js"
        }
    },
    "files": [
        "dist",
        "!dist/gh-pages",
        "!dist/gh-pages/**"
    ],
    "scripts": {
        "dev": "scripts/dev/dev.sh up",
        "predev:web-only": "test -f dist/value.js || npm run build",
        "dev:web-only": "vite --port 9000",
        "build": "vite build --mode production",
        "build:watch": "vite build --mode production --watch",
        "gh-pages": "vite build --mode gh-pages",
        "prepare": "test -f dist/value.js || npm run build",
        "bench": "node bench/color-channel-access.mjs && node bench/color2-direct-paths.mjs && node bench/parser-namelookup.mjs && node bench/computed-endpoint.mjs && node bench/color-soa-fold.mjs",
        "pretypecheck": "npm run build",
        "typecheck": "vue-tsc -p tsconfig.lib.json --noEmit && vue-tsc -p tsconfig.demo.json --noEmit",
        "lint": "eslint . --max-warnings=0",
        "test": "vitest",
        "test:e2e": "playwright test",
        "test:dist": "npm run build && npm run proof:dts-surface && npm run proof:css-parity && npm run proof:round-trip-idempotent && npm run proof:perf-target && npm run proof:serialize-fidelity && npm run proof:subpath-budget && npm run proof:lib-correctness && npm run proof:barrel-parity && npm run proof:pack-manifest && npm run proof:close-ledger",
        "boot-smoke": "node scripts/ci/boot-smoke.mjs",
        "abrogation-sweep": "node scripts/ci/abrogation-sweep.mjs",
        "css-emission-probe": "node scripts/ci/css-emission-probe.mjs",
        "proof:dts-surface": "node scripts/gates/proof-dts-surface.mjs",
        "proof:css-parity": "node scripts/gates/proof-css-parity.mjs",
        "proof:round-trip-idempotent": "node scripts/gates/proof-round-trip-idempotent.mjs",
        "proof:perf-target": "node scripts/gates/proof-perf-target.mjs",
        "proof:serialize-fidelity": "node scripts/gates/proof-serialize-fidelity.mjs",
        "proof:subpath-budget": "node scripts/gates/proof-subpath-budget.mjs",
        "proof:lib-correctness": "node scripts/gates/proof-lib-correctness.mjs",
        "proof:barrel-parity": "node scripts/gates/proof-barrel-parity.mjs",
        "proof:pack-manifest": "node scripts/gates/proof-pack-manifest.mjs",
        "proof:size-graph": "node scripts/gates/proof-size-graph.mjs",
        "proof:close-ledger": "node scripts/gates/proof-close-ledger.mjs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mkbabb/value.js.git"
    },
    "author": "",
    "engines": {
        "node": ">=22"
    },
    "bugs": {
        "url": "https://github.com/mkbabb/value.js/issues"
    },
    "homepage": "https://github.com/mkbabb/value.js#readme",
    "dependencies": {
        "@mkbabb/parse-that": "^1.0.0"
    },
    "peerDependencies": {
        "prettier": "^3.0.0"
    },
    "peerDependenciesMeta": {
        "prettier": {
            "optional": true
        }
    },
    "devDependencies": {
        "@lucide/vue": "^1.16.0",
        "@mkbabb/glass-ui": "file:../glass-ui",
        "@mkbabb/keyframes.js": "file:../keyframes.js",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/katex": "^0.16.8",
        "@types/node": "^24.12.3",
        "@types/sortablejs": "^1.15.9",
        "@typescript-eslint/eslint-plugin": "^8.59.4",
        "@typescript-eslint/parser": "^8.59.4",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/test-utils": "^2.4.10",
        "@vueuse/core": "^14.3.0",
        "@vueuse/integrations": "^14.3.0",
        "clsx": "^2.1.1",
        "eslint": "^10.4.0",
        "eslint-plugin-vue": "^10.9.1",
        "highlight.js": "^11.11.1",
        "jsdom": "^26.1.0",
        "katex": "^0.16.47",
        "prettier": "^3.8.3",
        "reka-ui": "^2.9",
        "sortablejs": "^1.15.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "unplugin-vue-markdown": "^32.0.0",
        "vite": "^8.0.13",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^3.2.4",
        "vue": "^3.5.34",
        "vue-eslint-parser": "^10.4.0",
        "vue-router": "^5.1.0",
        "vue-tsc": "^3.3.1"
    }
}
