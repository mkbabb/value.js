{
    "name": "@mkbabb/value.js",
    "version": "4.0.0",
    "description": "Immutable, failure-explicit CSS color, value, easing, transform, math, and quantization capabilities.",
    "license": "MIT",
    "keywords": [
        "css",
        "value",
        "color",
        "color-space",
        "easing",
        "transform",
        "quantization",
        "palette",
        "rgb",
        "xyz",
        "lab"
    ],
    "type": "module",
    "sideEffects": false,
    "exports": {
        "./color": {
            "types": "./dist/subpaths/color.d.ts",
            "import": "./dist/subpaths/color.js"
        },
        "./value": {
            "types": "./dist/subpaths/value.d.ts",
            "import": "./dist/subpaths/value.js"
        },
        "./css": {
            "types": "./dist/subpaths/css.d.ts",
            "import": "./dist/subpaths/css.js"
        },
        "./easing": {
            "types": "./dist/subpaths/easing.d.ts",
            "import": "./dist/subpaths/easing.js"
        },
        "./math": {
            "types": "./dist/subpaths/math.d.ts",
            "import": "./dist/subpaths/math.js"
        },
        "./transform": {
            "types": "./dist/subpaths/transform.d.ts",
            "import": "./dist/subpaths/transform.js"
        },
        "./quantize": {
            "types": "./dist/subpaths/quantize.d.ts",
            "import": "./dist/subpaths/quantize.js"
        }
    },
    "files": [
        "dist",
        "!dist/gh-pages",
        "!dist/gh-pages/**"
    ],
    "scripts": {
        "dev": "scripts/dev/dev.sh up",
        "predev:web-only": "npm run build",
        "dev:web-only": "vite --port 9000",
        "build": "vite build --mode production",
        "build:watch": "vite build --mode production --watch",
        "gh-pages": "vite build --mode gh-pages",
        "prepare": "rm -rf dist && npm run build",
        "pretypecheck": "npm run build",
        "typecheck": "vue-tsc -p tsconfig.lib.json --noEmit && vue-tsc -p tsconfig.demo.json --noEmit",
        "lint": "eslint . --max-warnings=0",
        "test": "vitest run",
        "test:e2e": "playwright test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mkbabb/value.js.git"
    },
    "author": "",
    "engines": {
        "node": ">=22"
    },
    "bugs": {
        "url": "https://github.com/mkbabb/value.js/issues"
    },
    "homepage": "https://github.com/mkbabb/value.js#readme",
    "devDependencies": {
        "@lucide/vue": "^1.16.0",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/katex": "^0.16.8",
        "@types/node": "^24.12.3",
        "@types/sortablejs": "^1.15.9",
        "@typescript-eslint/eslint-plugin": "^8.59.4",
        "@typescript-eslint/parser": "^8.59.4",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/test-utils": "^2.4.10",
        "@vueuse/core": "^14.3.0",
        "@vueuse/integrations": "^14.3.0",
        "clsx": "^2.1.1",
        "eslint": "^10.4.0",
        "eslint-plugin-vue": "^10.9.1",
        "highlight.js": "^11.11.1",
        "jsdom": "^26.1.0",
        "katex": "^0.16.47",
        "prettier": "^3.8.3",
        "reka-ui": "^2.9",
        "sortablejs": "^1.15.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "unplugin-vue-markdown": "^32.0.0",
        "vite": "^8.0.13",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^3.2.4",
        "vue": "^3.5.34",
        "vue-eslint-parser": "^10.4.0",
        "vue-router": "^5.1.0",
        "vue-tsc": "^3.3.1"
    }
}
