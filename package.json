{
    "name": "@mkbabb/value.js",
    "version": "0.7.0",
    "description": "CSS value units for color, length, angles, & c.",
    "license": "MIT",
    "keywords": [
        "css",
        "value",
        "unit",
        "value-unit",
        "css-value-unit",
        "color",
        "color-space",
        "rgb",
        "xyz",
        "lab"
    ],
    "type": "module",
    "main": "./dist/value.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/value.js",
            "default": "./dist/value.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite --port 9000",
        "dev:hero-lab": "vite --mode hero-lab --port 9010",
        "build": "vite build --mode production",
        "build:hero-lab": "vite build --mode hero-lab",
        "build:watch": "vite build --mode production --watch",
        "gh-pages": "vite build --mode gh-pages",
        "prepare": "test -f dist/value.js || npm run build",
        "proof:resolution": "node scripts/proof-resolution-contract.mjs",
        "codemod:keyframes-lerp": "node scripts/migrate-keyframes-js-lerp.mjs",
        "bench": "node bench/color-channel-access.mjs && node bench/color2-direct-paths.mjs && node bench/parser-namelookup.mjs",
        "typecheck": "vue-tsc --noEmit",
        "lint": "eslint . --max-warnings=0",
        "test": "vitest",
        "test:e2e": "playwright test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mkbabb/value.js.git"
    },
    "author": "",
    "engines": {
        "node": ">=22"
    },
    "bugs": {
        "url": "https://github.com/mkbabb/value.js/issues"
    },
    "homepage": "https://github.com/mkbabb/value.js#readme",
    "dependencies": {
        "@mkbabb/parse-that": "^0.8.2"
    },
    "devDependencies": {
        "@iconify-json/radix-icons": "^1.2.2",
        "@iconify/vue": "^4.1.2",
        "@mkbabb/glass-ui": "file:../glass-ui",
        "@mkbabb/keyframes.js": "file:../keyframes.js",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/cli": "^4.1.11",
        "@tailwindcss/postcss": "^4.1.11",
        "@types/katex": "^0.16.7",
        "@types/node": "^24.1.0",
        "@types/sortablejs": "^1.15.9",
        "@typescript-eslint/eslint-plugin": "^8.59.2",
        "@typescript-eslint/parser": "^8.59.2",
        "@unovis/ts": "^1.5.2",
        "@unovis/vue": "^1.5.2",
        "@vee-validate/zod": "^4.13.2",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/test-utils": "^2.4.6",
        "@vueuse/core": "^14.2.1",
        "@vueuse/integrations": "^14.2.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "embla-carousel-vue": "^8.6.0",
        "eslint": "^10.3.0",
        "eslint-plugin-vue": "^10.9.1",
        "globals": "^17.6.0",
        "highlight.js": "^11.11.1",
        "jsdom": "^26.1.0",
        "katex": "^0.16.22",
        "lucide-vue-next": "^0.525.0",
        "prettier": "^3.6.2",
        "reka-ui": "^2.0.0",
        "sortablejs": "^1.15.7",
        "tailwind-merge": "^3.3.1",
        "tailwindcss": "^4.1.11",
        "tw-animate-css": "^1.2.5",
        "typescript": "^5.8.3",
        "unplugin-vue-markdown": "^29.2.0",
        "v-calendar": "^3.1.2",
        "vaul-vue": "^0.2.0",
        "vee-validate": "^4.13.2",
        "vite": "^7.0.6",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^3.2.4",
        "vue": "^3.5.18",
        "vue-eslint-parser": "^10.4.0",
        "vue-router": "^4.6.4",
        "vue-tsc": "^2.2.0",
        "zod": "^3.23.8"
    }
}
