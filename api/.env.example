# MongoDB credentials (used by Docker Compose for container initialization)
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change-me-to-a-secure-root-password
MONGO_USER=palette
MONGO_PASSWORD=change-me-to-a-secure-app-password

# Admin API token (required for /admin/* endpoints)
ADMIN_TOKEN=change-me-to-a-secure-random-string

# Restrict CORS origins (comma-separated, required in production)
ALLOWED_ORIGINS=https://mkbabb.github.io

# Server port (default 3000)
PORT=3000
