# Admin API token (required for /admin/* endpoints)
ADMIN_TOKEN=change-me-to-a-secure-random-string

# Restrict CORS origins (comma-separated, required in production)
# Multi-origin format: production carries the color.babb.dev (primary demo)
# + fourier.babb.dev (cross-repo cohort peer; landed at fourier-E.W1 +
# value.js-I.W0 — cohort handshake for the `palette_slug` FK browser layer).
ALLOWED_ORIGINS=https://color.babb.dev,https://fourier.babb.dev

# Server port (default 3000)
PORT=3000
